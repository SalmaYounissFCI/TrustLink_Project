@{
    ViewData["Title"] = "Admin Dashboard - TrustLink";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">Admin Dashboard</h1>
        <p class="text-muted">Welcome, @User.Identity.Name</p>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Users</h5>
                    <h2 class="mb-0">@ViewBag.TotalUsers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Listings</h5>
                    <h2 class="mb-0">@ViewBag.TotalListings</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Total Contracts</h5>
                    <h2 class="mb-0">@ViewBag.TotalContracts</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body">
                    <h5 class="card-title">Open Reports</h5>
                    <h2 class="mb-0">@ViewBag.OpenReports</h2>
                </div>
            </div>
        </div>
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-info text-white">
                    <div class="card-body">
                        <h5 class="card-title">Contact Messages</h5>
                        <h2 class="mb-0">@ViewBag.TotalMessages</h2>
                    </div>
                </div>
            </div>
    </div>

    <!-- Management Cards -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-people fs-1 text-primary"></i>
                    <h5 class="mt-3">Users</h5>
                    <p>Manage and delete user accounts</p>
                    <a href="/Admin/Users" class="btn btn-primary">Manage Users</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-card-list fs-1 text-success"></i>
                    <h5 class="mt-3">Listings</h5>
                    <p>Delete inappropriate listings</p>
                    <a href="/Admin/Listings" class="btn btn-success">Manage Listings</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-flag fs-1 text-danger"></i>
                    <h5 class="mt-3">Reports</h5>
                    <p>Review and resolve reports</p>
                    <a href="/Admin/Reports" class="btn btn-danger">View Reports</a>
                </div>
            </div>
        </div>
        <div class="row g-4 mt-4">
            <div class="col-md-4">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-envelope fs-1 text-warning"></i>
                        <h5 class="mt-3">Contact Messages</h5>
                        <p>View and manage user inquiries</p>
                        <a href="/Admin/Messages" class="btn btn-warning">View Messages</a>
                    </div>
                </div>
            </div>
    </div>
</div>