@model SW_Project.ViewModels.Admin.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard - TrustLink";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6" style="font-family: 'Cormorant Garamond', serif;">Admin Dashboard</h1>
            <p class="text-muted">Welcome back, @User.Identity.Name. Monitor and manage your platform activities.</p>
        </div>
    </div>

    <!-- Stats Cards (الأرقام الإحصائية) -->
    <div class="row g-4 mb-5">
        <!-- Total Users -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white">
                <div class="card-body py-4">
                    <h6 class="text-uppercase mb-2" style="font-size: 0.8rem; opacity: 0.9;">Total Users</h6>
                    <h2 class="mb-0 fw-bold">@Model.TotalUsers</h2>
                </div>
            </div>
        </div>

        <!-- Total Listings -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white">
                <div class="card-body py-4">
                    <h6 class="text-uppercase mb-2" style="font-size: 0.8rem; opacity: 0.9;">Total Listings</h6>
                    <h2 class="mb-0 fw-bold">@Model.TotalListings</h2>
                </div>
            </div>
        </div>

        <!-- Total Contracts -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-white">
                <div class="card-body py-4">
                    <h6 class="text-uppercase mb-2" style="font-size: 0.8rem; opacity: 0.9;">Total Contracts</h6>
                    <h2 class="mb-0 fw-bold">@Model.TotalContracts</h2>
                </div>
            </div>
        </div>

        <!-- Open Reports -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white">
                <div class="card-body py-4">
                    <h6 class="text-uppercase mb-2" style="font-size: 0.8rem; opacity: 0.9;">Open Reports</h6>
                    <h2 class="mb-0 fw-bold">@Model.PendingReports</h2>
                </div>
            </div>
        </div>
        <div class="row g-4 mb-5">
            <div class="col-md-3">
                <div class="card border-0 shadow-sm bg-info text-white">
                    <div class="card-body">
                        <h5 class="card-title">Contact Messages</h5>
                        <h2 class="mb-0">@ViewBag.TotalMessages</h2>
                    </div>
                </div>
            </div>
    </div>

    <!-- Management Sections (أزرار الإدارة) -->
    <div class="row g-4">
        <!-- Users Management -->
        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100 border-0">
                <div class="card-body p-5">
                    <div class="mb-3">
                        <i class="bi bi-people fs-1 text-primary"></i>
                    </div>
                    <h5 class="fw-bold">Users</h5>
                    <p class="text-muted small">View, manage, and remove user accounts across the platform.</p>
                    <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-primary px-4 rounded-pill">Manage Users</a>
                </div>
            </div>
        </div>

        <!-- Listings Management -->
        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100 border-0">
                <div class="card-body p-5">
                    <div class="mb-3">
                        <i class="bi bi-card-list fs-1 text-success"></i>
                    </div>
                    <h5 class="fw-bold">Listings</h5>
                    <p class="text-muted small">Review all property listings and remove inappropriate content.</p>
                    <a asp-controller="Admin" asp-action="Listings" class="btn btn-outline-success px-4 rounded-pill">Manage Listings</a>
                </div>
            </div>
        </div>

        <!-- Reports Management -->
        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100 border-0">
                <div class="card-body p-5">
                    <div class="mb-3">
                        <i class="bi bi-flag fs-1 text-danger"></i>
                    </div>
                    <h5 class="fw-bold">Reports</h5>
                    <p class="text-muted small">Take action on user-reported issues and resolve disputes.</p>
                    <a asp-controller="Admin" asp-action="Reports" class="btn btn-outline-danger px-4 rounded-pill">View Reports</a>
                </div>
            </div>
        </div>
        <div class="row g-4 mt-4">
            <div class="col-md-4">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body">
                        <i class="bi bi-envelope fs-1 text-warning"></i>
                        <h5 class="mt-3">Contact Messages</h5>
                        <p>View and manage user inquiries</p>
                        <a href="/Admin/Messages" class="btn btn-warning">View Messages</a>
                    </div>
                </div>
            </div>
    </div>
</div>