@{
    ViewData["Title"] = "Admin Profile - TrustLink";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="container py-5">
    <div class="row">
        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px; font-size: 2.5rem;">
                        <i class="bi bi-shield-lock-fill"></i>
                    </div>
                    <h4>@User.Identity.Name</h4>
                    <p class="text-muted">System Administrator</p>
                    <span class="badge bg-danger">Admin</span>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 pt-4">
                    <h5 class="mb-0">Admin Information</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-4 text-muted">Email</div>
                        <div class="col-8">@User.Identity.Name</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-4 text-muted">Role</div>
                        <div class="col-8">Administrator</div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-4 text-muted">Permissions</div>
                        <div class="col-8">
                            <ul class="mb-0">
                                <li>Manage Users</li>
                                <li>Manage Listings</li>
                                <li>Manage Contracts</li>
                                <li>Manage Reports</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>