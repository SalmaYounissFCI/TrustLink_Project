@model SW_Project.ViewModels.Payment.PaymentCheckoutVM
@{
    ViewData["Title"] = "Checkout";
}

<section class="page-hero">
    <div class="container">
        <span class="page-hero-eyebrow">
            <i class="bi bi-credit-card me-1"></i> Secure Payment
        </span>
        <h1 class="page-hero-title">
            Complete <em>Payment</em>
        </h1>
        <p class="page-hero-desc">
            You're about to complete your contract payment. All transactions are secure and encrypted.
        </p>
    </div>
</section>

<section class="section-pad bg-ivory">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                    <div class="card-header bg-navy text-white text-center py-4">
                        <i class="bi bi-shield-check fs-1 text-gold"></i>
                        <h3 class="mt-2 mb-0">Payment Summary</h3>
                    </div>
                    <div class="card-body p-4 p-md-5">
                        <div class="text-center mb-4 pb-2 border-bottom">
                            <h5 class="text-muted mb-2">Contract</h5>
                            <h4 class="text-navy">@Model.ContractTitle</h4>
                            <p class="text-muted">Contract #@Model.ContractId</p>
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <small class="text-muted">Amount Due</small>
                                <h2 class="text-gold">@Model.Amount.ToString("C")</h2>
                            </div>
                            <div class="col-6 text-end">
                                <small class="text-muted">Currency</small>
                                <h5>@Model.Currency.ToUpper()</h5>
                            </div>
                        </div>

                        <form asp-action="CreateCheckoutSession" method="post">
                            <input type="hidden" name="contractId" value="@Model.ContractId" />
                            <button type="submit" class="btn-gold-tl w-100 py-3">
                                <i class="bi bi-lock"></i> Pay Securely with Stripe
                            </button>
                        </form>

                        <div class="text-center mt-4">
                            <small class="text-muted">
                                <i class="bi bi-shield-check"></i> Secure payment powered by Stripe
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
