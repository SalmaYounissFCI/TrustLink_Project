@{
    ViewData["Title"] = "Payment Cancelled";
    var contractId = ViewBag.ContractId;
    var contractTitle = ViewBag.ContractTitle;
}

<section class="page-hero">
    <div class="container">
        <span class="page-hero-eyebrow">
            <i class="bi bi-x-circle me-1"></i> Cancelled
        </span>
        <h1 class="page-hero-title">
            Payment <em>Cancelled</em>
        </h1>
    </div>
</section>

<section class="section-pad bg-ivory">
    <div class="container text-center">
        <div class="card shadow-lg border-0 rounded-4 p-5 mx-auto" style="max-width: 500px;">
            <div class="mb-4">
                <div class="mx-auto bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px;">
                    <i class="bi bi-x-lg text-warning fs-1"></i>
                </div>
            </div>
            <h1 class="text-warning mb-3">Payment Cancelled</h1>
            <p class="lead">You cancelled the payment process.</p>
            <p class="text-muted">Contract #@contractId - @contractTitle</p>
            <hr />
            <div class="d-flex gap-3 justify-content-center">
                <a asp-controller="Payment" asp-action="Checkout" asp-route-contractId="@contractId"
                   class="btn-gold-tl">
                    <i class="bi bi-arrow-repeat"></i> Try Again
                </a>
                <a asp-controller="Contracts" asp-action="Details" asp-route-id="@contractId"
                   class="btn-outline-tl">
                    <i class="bi bi-arrow-left"></i> Back to Contract
                </a>
            </div>
        </div>
    </div>
</section>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
