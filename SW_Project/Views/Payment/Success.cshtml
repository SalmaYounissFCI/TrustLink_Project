@model SW_Project.ViewModels.Payment.PaymentCheckoutVM
@{
    ViewData["Title"] = "Payment Successful";
}

<section class="page-hero">
    <div class="container">
        <span class="page-hero-eyebrow">
            <i class="bi bi-check-circle me-1"></i> Success
        </span>
        <h1 class="page-hero-title">
            Payment <em>Successful!</em>
        </h1>
    </div>
</section>

<section class="section-pad bg-ivory">
    <div class="container text-center">
        <div class="card shadow-lg border-0 rounded-4 p-5 mx-auto" style="max-width: 500px;">
            <div class="mb-4">
                <div class="mx-auto bg-success bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center"
                     style="width: 80px; height: 80px;">
                    <i class="bi bi-check-lg text-success fs-1"></i>
                </div>
            </div>
            <h1 class="text-success mb-3">Thank You!</h1>
            <p class="lead">Your payment has been received successfully.</p>
            <p class="text-muted">Contract #@Model.ContractId - @Model.ContractTitle</p>

            @if (ViewBag.IsPaid)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle"></i> Your contract is now active.
                </div>
            }

            <hr />
            <a asp-controller="Contracts" asp-action="Details" asp-route-id="@Model.ContractId"
               class="btn-gold-tl mt-3">
                <i class="bi bi-file-earmark-text"></i> View Contract
            </a>
        </div>
    </div>
</section>@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
