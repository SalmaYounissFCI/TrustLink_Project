@model List<SW_Project.ViewModels.Booking.MyBookingVM>
@using SW_Project.ViewModels.Booking
@{
    ViewData["Title"] = "My Bookings — TrustLink";
    if (User.IsInRole("Admin"))
    {
        Layout = null;
        <script>window.location.href = '/Admin';</script>
        return;
    }
    Layout = null;
    var userId = ViewBag.UserId as string;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">Trust<span>Link</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center gap-2">
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a href="/Listings/Create" class="btn-post-listing">+ Post Listing</a></li>
                        <li class="nav-item"><a href="/Listings/MyListings" class="nav-link-custom">My Listings</a></li>
                        <li class="nav-item"><a href="/Bookings/MyBookings" class="nav-link-custom">My Bookings</a></li>
                        <li class="nav-item"><a href="/Favorites" class="nav-link-custom">Favorites</a></li>
                        <li class="nav-item"><a href="/Bookings/ReceivedBookings" class="nav-link-custom">Received Bookings</a></li>
                        <li class="nav-item"><a href="/Contracts/MyContracts" class="nav-link-custom">My Contracts</a></li>
                        <li class="nav-item position-relative">
                            <a class="nav-link notification-bell" href="/Notifications" id="notificationBell">
                                <i class="bi bi-bell-fill"></i>
                                <span id="notif-badge" class="topbar-notif-badge" style="display: none;">0</span>
                                <span id="notif-dot" class="notification-dot" style="display: none;"></span>
                            </a>
                        </li>
                        <li class="nav-item"><a href="/Account/Profile" class="nav-link-custom">Profile</a></li>
                        <li class="nav-item"><a href="/Account/Logout" class="nav-link-custom">Logout</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a href="/Account/Login" class="btn-outline-tl-nav">Sign In</a></li>
                        <li class="nav-item"><a href="/Account/Register" class="btn-nav-cta-nav">Get Started</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="page-hero" style="padding: 8rem 0 3.5rem;">
        <div class="container">
            <div class="col-lg-8">
                <span class="page-hero-eyebrow">My Account</span>
                <h1 class="page-hero-title">My <em>Bookings</em></h1>
                <p class="page-hero-desc">All your rental requests and their status.</p>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="profile-section" style="padding: 2rem 0 5rem;">
        <div class="container">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-calendar-x" style="font-size: 4rem; color: var(--slate-light);"></i>
                    <h3>No bookings yet</h3>
                    <p>Browse listings and make your first booking.</p>
                    <a href="/Listings" class="btn-primary-tl">Explore Listings</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var booking in Model)
                    {
                        var revieweeId = booking.RenterId == userId ? booking.OwnerId : booking.RenterId;
                        var isEffectivelyCompleted = booking.Status == "Completed" || booking.IsExpired;

                        <div class="col-md-6 col-lg-4">
                            <div class="profile-card">
                                <div class="profile-header" style="padding: 1rem;">
                                    <div class="profile-avatar" style="width: 60px; height: 60px; font-size: 1.5rem;">
                                        @(booking.ListingTitle.Substring(0, 1).ToUpper())
                                    </div>
                                    <h3 style="font-size: 1.1rem;" class="mt-2">@booking.ListingTitle</h3>
                                </div>
                                <div class="profile-body">
                                    <p><i class="bi bi-calendar-week"></i> @booking.StartDate.ToString("MMM dd") - @booking.EndDate.ToString("MMM dd, yyyy")</p>
                                    <p><strong>Total:</strong> $@booking.TotalPrice</p>
                                    <p>
                                        <span class="badge" style="background: @booking.StatusColor; color:white;">
                                            @booking.DisplayStatus
                                        </span>
                                    </p>

                                    <!-- ✅ View Listing Button - Goes to Listing Details -->
                                    <a href="/Listings/Details/@booking.ListingId" class="listing-card-btn d-block text-center mb-2">
                                        <i class="bi bi-eye"></i> View Listing
                                    </a>

                                    @if (booking.IsActive && booking.Status != "Completed")
                                    {
                                        <form method="post" asp-action="Complete" asp-controller="Bookings" class="mt-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@booking.Id" />
                                            <button type="submit" class="btn-outline-tl btn-sm w-100">
                                                <i class="bi bi-check2-circle"></i> Mark as Completed
                                            </button>
                                        </form>
                                    }

                                    @if (isEffectivelyCompleted && !booking.HasReviewed)
                                    {
                                        <div class="mt-2">
                                            <a href="/Reviews/Create?bookingId=@booking.Id&revieweeId=@revieweeId" class="btn-primary-tl btn-sm w-100">
                                                <i class="bi bi-star"></i> Write Review
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <!-- Footer -->
    <footer class="tl-footer">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4 col-md-6">
                    <a class="footer-brand" href="/">Trust<span>Link</span></a>
                    <p class="footer-desc">Smart resource sharing backed by legally binding digital contracts.</p>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Platform</div>
                    <ul class="footer-links">
                        <li><a href="/Listings">Browse Listings</a></li>
                        <li><a href="/Home/HowItWorks">How It Works</a></li>
                        <li><a href="/Account/Login">Sign In</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Company</div>
                    <ul class="footer-links">
                        <li><a href="/Home/About">About Us</a></li>
                        <li><a href="/Home/Contact">Contact</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="footer-copyright">&copy; 2024 TrustLink. All rights reserved.</div>
                <div class="footer-social">
                    <a href="#"><i class="bi bi-twitter-x"></i></a>
                    <a href="#"><i class="bi bi-linkedin"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Notification count
        fetch('/Notifications/GetUnreadCount')
        .then(response => response.json())
        .then(data => {
        if (data.count > 0) {
        const badge = document.getElementById('notif-badge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
        }
        })
        .catch(error => console.error('Error:', error));
    </script>
</body>
</html>