@model List<SW_Project.Models.Notification>
@{
    ViewData["Title"] = "Notifications — TrustLink";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
    <style>
        .notification-item {
            transition: all 0.2s ease;
            border-left: 3px solid transparent;
        }
        .notification-item.unread {
            background-color: rgba(201, 168, 76, 0.05);
            border-left-color: var(--gold);
        }
        .notification-item:hover {
            background-color: var(--ivory-dark);
        }
        .notification-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }
        .notification-icon.booking { background: rgba(15,31,61,0.1); color: var(--navy); }
        .notification-icon.contract { background: rgba(201,168,76,0.15); color: var(--gold); }
        .notification-icon.message { background: rgba(46,204,113,0.1); color: #2ecc71; }
        .notification-icon.default { background: var(--ivory-dark); color: var(--slate); }
        .topbar-notif-badge {
    position: absolute;
    top: -8px;
    right: -12px;
    background: #c9a84c;
    color: #0f1f3d;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    font-size: 0.65rem;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: center;
}
    </style>
</head>
<body>

<nav class="tl-navbar navbar navbar-expand-lg">
    <div class="container">
        <a class="navbar-brand" href="/">Trust<span>Link</span></a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav ms-auto me-4 gap-1">
                <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="/Listings">Browse</a></li>
                <li class="nav-item"><a class="nav-link" href="/Notifications">Notifications</a></li>
                <li class="nav-item"><a class="nav-link" href="/Account/Profile">Profile</a></li>
                <li class="nav-item"><a class="btn-nav-cta" href="/Account/Logout">Logout</a></li>
            </ul>
        </div>
    </div>
</nav>

<section class="page-hero" style="padding: 6rem 0 2rem;">
    <div class="container">
        <div class="col-lg-8 mx-auto">
            <span class="page-hero-eyebrow">Stay Updated</span>
            <h1 class="page-hero-title">Your <em>Notifications</em></h1>
        </div>
    </div>
</section>

<section class="profile-section" style="padding-top: 0;">
    <div class="container">
        <div class="card shadow-sm border-0" style="border-radius: var(--radius-lg);">
            <div class="card-header bg-white d-flex justify-content-between align-items-center" style="border-bottom: 1px solid var(--border); padding: 1rem 1.5rem;">
                <h5 class="mb-0">All Notifications</h5>
                @if (Model.Any(n => !n.IsRead))
                {
                    <form method="post" asp-action="MarkAllAsRead" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Mark all as read</button>
                    </form>
                }
            </div>
            <div class="card-body p-0">
                @if (!Model.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-bell-slash" style="font-size: 3rem; color: var(--slate-light);"></i>
                        <p class="mt-3 text-muted">No notifications yet.</p>
                    </div>
                }
                else
                {
                    @foreach (var notif in Model)
                    {
                        string iconClass = "default";
                        if (notif.Type.Contains("Booking")) iconClass = "booking";
                        else if (notif.Type.Contains("Contract") || notif.Type.Contains("Signature")) iconClass = "contract";
                        else if (notif.Type.Contains("Message")) iconClass = "message";

                        <div class="notification-item d-flex align-items-start gap-3 p-3 @(!notif.IsRead ? "unread" : "")" data-id="@notif.Id" data-url="@notif.LinkUrl">
                            <div class="notification-icon @iconClass">
                                <i class="bi @(notif.Type switch {
                                    "BookingRequest" => "bi-calendar-plus",
                                    "BookingAccepted" => "bi-check-circle",
                                    "BookingRejected" => "bi-x-circle",
                                    "ContractReady" => "bi-file-earmark-text",
                                    "ContractSigned" => "bi-pen",
                                    "NewMessage" => "bi-chat-dots",
                                    _ => "bi-bell"
                                })"></i>
                            </div>
                            <div class="flex-grow-1">
                                <p class="mb-1">@notif.Message</p>
                                <small class="text-muted">@notif.CreatedAt.ToString("MMMM dd, yyyy • h:mm tt")</small>
                            </div>
                            @if (!notif.IsRead)
                            {
                                <button class="btn btn-sm btn-link mark-read-btn" data-id="@notif.Id" style="color: var(--gold);">Mark as read</button>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</section>

<footer class="tl-footer mt-5">...</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/script.js"></script>
<script>
    // Mark single notification as read
    document.querySelectorAll('.mark-read-btn').forEach(btn => {
        btn.addEventListener('click', async function(e) {
            e.preventDefault();
            const id = this.dataset.id;
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            if (!token) return;
            const response = await fetch(`/Notifications/MarkAsRead/${id}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            });
            if (response.ok) {
                const item = this.closest('.notification-item');
                item.classList.remove('unread');
                this.remove();
                // تحديث العداد في النافبار
                updateNotificationCount();
            }
        });
    });

    // عند النقر على الإشعار، انتقل إلى الرابط
    document.querySelectorAll('.notification-item').forEach(item => {
        const url = item.dataset.url;
        if (url) {
            item.style.cursor = 'pointer';
            item.addEventListener('click', function(e) {
                if (e.target.tagName !== 'BUTTON') {
                    window.location.href = url;
                }
            });
        }
    });

    function updateNotificationCount() {
        fetch('/Notifications/GetUnreadCount')
            .then(res => res.json())
            .then(count => {
                const badge = document.getElementById('notif-badge');
                if (badge) {
                    if (count > 0) {
                        badge.textContent = count > 99 ? '99+' : count;
                        badge.style.display = 'flex';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            });
    }
</script>
</body>
</html>