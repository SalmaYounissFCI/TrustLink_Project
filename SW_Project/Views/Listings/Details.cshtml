@using SW_Project.ViewModels.Listing
@using SW_Project.Interfaces
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> _userManager
@inject IUnitOfWork _unitOfWork
@model ListingDetailsVM
@{
    ViewData["Title"] = Model.Title;
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
    <style>
            .btn-outline-tl.disabled-btn, .btn-outline-tl:disabled {
                opacity: 0.5;
                cursor: not-allowed;
                pointer-events: none;
            }

            .already-booked-btn {
                background-color: #6c757d;
                color: white;
                border: none;
                padding: 0.6rem 1.5rem;
                border-radius: 8px;
                font-weight: 600;
                cursor: not-allowed;
                opacity: 0.6;
            }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg fixed-top">
        <div class="container">
            <a class="navbar-brand" href="/">Trust<span>Link</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center gap-2">
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a href="/Listings/Create" class="btn-post-listing">+ Post Listing</a></li>
                        <li class="nav-item"><a href="/Listings/MyListings" class="nav-link-custom">My Listings</a></li>
                        <li class="nav-item"><a href="/Bookings/MyBookings" class="nav-link-custom">My Bookings</a></li>
                        <li class="nav-item"><a href="/Favorites" class="nav-link-custom">Favorites</a></li>
                        <li class="nav-item"><a href="/Bookings/ReceivedBookings" class="nav-link-custom">Received Bookings</a></li>
                        <li class="nav-item"><a href="/Contracts/MyContracts" class="nav-link-custom">My Contracts</a></li>
                        <li class="nav-item position-relative">
                            <a class="nav-link notification-bell" href="/Notifications" id="notificationBell">
                                <i class="bi bi-bell-fill"></i>
                                <span id="notif-badge" class="topbar-notif-badge" style="display: none;">0</span>
                                <span id="notif-dot" class="notification-dot" style="display: none;"></span>
                            </a>
                        </li>
                        <li class="nav-item"><a href="/Account/Profile" class="nav-link-custom">Profile</a></li>
                        <li class="nav-item"><a href="/Account/Logout" class="nav-link-custom">Logout</a></li>
                    }
                    else
                    {
                        <li class="nav-item"><a href="/Account/Login" class="btn-outline-tl-nav">Sign In</a></li>
                        <li class="nav-item"><a href="/Account/Register" class="btn-nav-cta-nav">Get Started</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="page-hero" style="padding: 6rem 0 2rem;">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <span class="page-hero-eyebrow">@Model.CategoryName</span>
                    <h1 class="page-hero-title">@Model.Title</h1>
                    <p class="page-hero-desc"><i class="bi bi-geo-alt"></i> @Model.Location</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content -->
    <section class="profile-section">
        <div class="container">
            <div class="row g-4">
                <!-- Left Column - Images and Description -->
                <div class="col-lg-8">
                    @if (Model.ImageUrls != null && Model.ImageUrls.Any())
                    {
                        <div id="listingCarousel" class="carousel slide mb-4" data-bs-ride="carousel">
                            <div class="carousel-inner">
                                @for (int i = 0; i < Model.ImageUrls.Count; i++)
                                {
                                    <div class="carousel-item @(i == 0 ? "active" : "")">
                                        <img src="@Model.ImageUrls[i]" class="d-block w-100" alt="Listing image" style="border-radius: var(--radius-md); max-height: 400px; object-fit: cover;">
                                    </div>
                                }
                            </div>
                            @if (Model.ImageUrls.Count > 1)
                            {
                                <button class="carousel-control-prev" type="button" data-bs-target="#listingCarousel" data-bs-slide="prev">
                                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Previous</span>
                                </button>
                                <button class="carousel-control-next" type="button" data-bs-target="#listingCarousel" data-bs-slide="next">
                                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                                    <span class="visually-hidden">Next</span>
                                </button>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="listing-card-image-placeholder mb-4" style="height: 300px; display: flex; align-items: center; justify-content: center; background: var(--ivory-dark); border-radius: var(--radius-md);">
                            <i class="bi bi-image" style="font-size: 4rem; color: var(--slate-light);"></i>
                        </div>
                    }

                    <div class="profile-card" style="padding: 2rem;">
                        <h3>Description</h3>
                        <p>@Model.Description</p>
                        <hr />
                        <h4>Price: <span class="text-gold">$@Model.PricePerDay</span> / day</h4>
                        @if (Model.Deposit.HasValue)
                        {
                            <p><strong>Deposit:</strong> $@Model.Deposit</p>
                        }

                        <!-- Action Buttons -->
                        <div class="mt-4 d-flex gap-3 flex-wrap">
                            @if (User?.Identity?.IsAuthenticated == true)
                            {
                                var currentUserId = _userManager.GetUserId(User);
                                
                                // التحقق من وجود حجز نشط لنفس المستخدم
                                var hasActiveBooking = false;
                                var activeBooking = await _unitOfWork.Bookings.FindAsync(b =>
                                    b.ListingId == Model.Id &&
                                    b.RenterId == currentUserId &&
                                    (b.Status == "Pending" || b.Status == "Accepted" || b.Status == "Active"));
                                hasActiveBooking = activeBooking != null;

                                // المالك للإعلان
                                if (Model.IsOwner)
                                {
                                    <a href="/Listings/Edit/@Model.Id" class="btn-primary-tl">Edit Listing</a>
                                    <a href="/Listings/Delete/@Model.Id" class="btn-danger-tl">Delete Listing</a>
                                }
                                // الإعلان متاح و مفيش حجز نشط للمستخدم
                                else if (Model.IsAvailable && !hasActiveBooking)
                                {
                                    <a href="/Bookings/Create?listingId=@Model.Id" class="btn-primary-tl">Book Now</a>
                                    <button class="btn-outline-tl" id="messageOwnerBtn">Message Owner</button>
                                    <a href="/Reports/Create?listingId=@Model.Id" class="btn-outline-tl" style="border-color: #dc3545; color: #dc3545;">
                                        <i class="bi bi-flag"></i> Report Listing
                                    </a>
                                }
                                // الإعلان متاح بس فيه حجز نشط للمستخدم
                                else if (Model.IsAvailable && hasActiveBooking)
                                {
                                    <button class="already-booked-btn" disabled>
                                        <i class="bi bi-check-circle"></i> Already Booked
                                    </button>
                                    <button class="btn-outline-tl" id="messageOwnerBtn">Message Owner</button>
                                    <a href="/Reports/Create?listingId=@Model.Id" class="btn-outline-tl" style="border-color: #dc3545; color: #dc3545;">
                                        <i class="bi bi-flag"></i> Report Listing
                                    </a>
                                }
                                // الإعلان مش متاح
                                else if (!Model.IsAvailable)
                                {
                                    <button class="btn-secondary-tl" disabled>Currently Rented</button>
                                    <button class="btn-outline-tl" id="messageOwnerBtn">Message Owner</button>
                                    <a href="/Reports/Create?listingId=@Model.Id" class="btn-outline-tl" style="border-color: #dc3545; color: #dc3545;">
                                        <i class="bi bi-flag"></i> Report Listing
                                    </a>
                                }
                            }
                            else
                            {
                                // User not logged in
                                <a href="/Account/Login" class="btn-primary-tl">Sign in to Book</a>
                                <button class="btn-outline-tl" id="messageOwnerBtnGuest">Message Owner</button>
                            }
                        </div>
                    </div>
                </div>

                <!-- Right Column - Owner Info -->
                <div class="col-lg-4">
                    <div class="profile-card">
                        <div class="profile-header">
                            <div class="profile-avatar">
                                @Model.OwnerAvatar
                            </div>
                            <h3 class="profile-name">@Model.OwnerName</h3>
                            <div class="profile-email">@Model.OwnerEmail</div>
                        </div>
                        <div class="profile-body">
                            <div class="info-row">
                                <span class="info-label"><i class="bi bi-calendar3"></i> Member since</span>
                                <span class="info-value">@Model.OwnerJoinedAt.ToString("MMMM yyyy")</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><i class="bi bi-star-fill"></i> Rating</span>
                                <span class="info-value">@Model.OwnerRating.ToString("0.0") / 5.0</span>
                            </div>
                            <div class="info-row">
                                <span class="info-label"><i class="bi bi-geo-alt"></i> Location</span>
                                <span class="info-value">@Model.OwnerLocation</span>
                            </div>
                            
                            @* Report User button - only if not the owner and authenticated *@
                            @if (User?.Identity?.IsAuthenticated == true && !Model.IsOwner)
                            {
                                <div class="mt-3">
                                    <a href="/Reports/Create?reportedUserId=@Model.OwnerId" class="btn btn-outline-danger btn-sm w-100">
                                        <i class="bi bi-flag"></i> Report this User
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="tl-footer">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4 col-md-6">
                    <a class="footer-brand" href="/">Trust<span>Link</span></a>
                    <p class="footer-desc">Smart resource sharing backed by legally binding digital contracts.</p>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Platform</div>
                    <ul class="footer-links">
                        <li><a href="/Listings">Browse Listings</a></li>
                        <li><a href="/Home/HowItWorks">How It Works</a></li>
                        <li><a href="/Account/Login">Sign In</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Company</div>
                    <ul class="footer-links">
                        <li><a href="/Home/About">About Us</a></li>
                        <li><a href="/Home/Contact">Contact</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="footer-copyright">&copy; 2024 TrustLink. All rights reserved.</div>
                <div class="footer-social">
                    <a href="#"><i class="bi bi-twitter-x"></i></a>
                    <a href="#"><i class="bi bi-linkedin"></i></a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Message button event listener for logged in users
        var messageBtn = document.getElementById('messageOwnerBtn');
        if (messageBtn) {
        messageBtn.addEventListener('click', function(e) {
        e.preventDefault();
        window.location.href = '/Messages/Conversation?userId=@Model.OwnerId&listingId=@Model.Id';
        });
        }
        
        // Message button for guests
        var messageBtnGuest = document.getElementById('messageOwnerBtnGuest');
        if (messageBtnGuest) {
        messageBtnGuest.addEventListener('click', function(e) {
        e.preventDefault();
        window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
        });
        }
        
        // Notification count
        fetch('/Notifications/GetUnreadCount')
        .then(response => response.json())
        .then(data => {
        if (data.count > 0) {
        const badge = document.getElementById('notif-badge');
        badge.textContent = data.count;
        badge.style.display = 'inline-block';
        }
        })
        .catch(error => console.error('Error fetching notifications:', error));
    </script>
</body>
</html>