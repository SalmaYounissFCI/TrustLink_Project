@using SW_Project.ViewModels.Report
@model List<ReportIndexVM>
@{
    ViewData["Title"] = "إدارة البلاغات";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-hero" style="padding: 6rem 0 3rem;">
    <div class="container">
        <span class="page-hero-eyebrow">Admin Dashboard</span>
        <h1 class="page-hero-title">إدارة البلاغات</h1>
        <p class="page-hero-desc">مراجعة وحل البلاغات الواردة من المستخدمين</p>
    </div>
</section>

<section class="profile-section" style="padding: 2rem 0 5rem;">
    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row mb-4">
            <div class="col-auto ms-auto">
                <span class="badge bg-danger p-2 fs-6">
                    <i class="bi bi-flag"></i> غير محلول: @Model.Count(r => !r.IsResolved)
                </span>
                <span class="badge bg-success p-2 fs-6 ms-2">
                    <i class="bi bi-check-circle"></i> محلول: @Model.Count(r => r.IsResolved)
                </span>
            </div>
        </div>

        <div class="profile-card" style="padding: 0; overflow: hidden;">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background: var(--navy); color: var(--ivory);">
                        <tr>
                            <th style="padding: 1rem;">#</th>
                            <th style="padding: 1rem;">المبلغ</th>
                            <th style="padding: 1rem;">المبلغ ضده</th>
                            <th style="padding: 1rem;">سبب البلاغ</th>
                            <th style="padding: 1rem;">التاريخ</th>
                            <th style="padding: 1rem;">الحالة</th>
                            <th style="padding: 1rem;">إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in Model)
                        {
                            <tr style="@(report.IsResolved ? "opacity:0.7;" : "")">
                                <td class="align-middle">@report.Id</td>
                                <td class="align-middle">
                                    <div><strong>@report.ReporterName</strong></div>
                                    <small class="text-muted">@report.ReporterEmail</small>
                                </td>
                                <td class="align-middle">
                                    @if (report.Type == "Listing")
                                    {
                                        <span class="badge bg-info">إعلان</span>
                                        <div class="mt-1">
                                            <a href="/Listings/Details/@report.ReportedListingId" target="_blank">
                                                @report.ReportedListingTitle
                                            </a>
                                        </div>
                                    }
                                    else if (report.Type == "User")
                                    {
                                        <span class="badge bg-warning">مستخدم</span>
                                        <div class="mt-1">@report.ReportedUserEmail</div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">عام</span>
                                    }
                                </td>
                                <td class="align-middle" style="max-width: 300px; white-space: normal;">
                                    @report.Reason
                                </td>
                                <td class="align-middle">@report.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="align-middle">
                                    @if (report.IsResolved)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> تم الحل
                                        </span>
                                        <br />
                                        <small class="text-muted">@(report.ResolvedAt?.ToString("yyyy-MM-dd"))</small>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-clock"></i> قيد المراجعة
                                        </span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @if (!report.IsResolved)
                                    {
                                        <form method="post" asp-action="Resolve" asp-route-id="@report.Id" style="display: inline-block;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success"
                                                    onclick="return confirm('هل أنت متأكد من حل هذا البلاغ؟')">
                                                <i class="bi bi-check-lg"></i> حل
                                            </button>
                                        </form>
                                    }
                                    
                                    <form method="post" asp-action="Delete" asp-route-id="@report.Id" style="display: inline-block;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('هل أنت متأكد من حذف هذا البلاغ؟')">
                                            <i class="bi bi-trash"></i> حذف
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 4rem; color: var(--slate-light);"></i>
                <h3 class="mt-3 text-muted">لا توجد بلاغات</h3>
                <p class="text-muted">عند قيام المستخدمين بالإبلاغ عن مخالفات، ستظهر هنا</p>
            </div>
        }
    </div>
</section>