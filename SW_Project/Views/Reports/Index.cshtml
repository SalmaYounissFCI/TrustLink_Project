@using SW_Project.ViewModels.Report
@model List<ReportIndexVM>
@{
    ViewData["Title"] = "Reports Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-hero" style="padding: 6rem 0 3rem;">
    <div class="container">
        <span class="page-hero-eyebrow">Admin Dashboard</span>
        <h1 class="page-hero-title">Reports Management</h1>
        <p class="page-hero-desc">Review and resolve user reports</p>
    </div>
</section>

<section class="profile-section" style="padding: 2rem 0 5rem;">
    <div class="container">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="row mb-4">
            <div class="col-auto ms-auto">
                <span class="badge bg-danger p-2 fs-6">
                    <i class="bi bi-flag"></i> Pending: @Model.Count(r => !r.IsResolved)
                </span>
                <span class="badge bg-success p-2 fs-6 ms-2">
                    <i class="bi bi-check-circle"></i> Resolved: @Model.Count(r => r.IsResolved)
                </span>
            </div>
        </div>

        <div class="profile-card" style="padding: 0; overflow: hidden;">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background: var(--navy); color: var(--ivory);">
                        <tr>
                            <th style="padding: 1rem;">ID</th>
                            <th style="padding: 1rem;">Reporter</th>
                            <th style="padding: 1rem;">Reported Item</th>
                            <th style="padding: 1rem;">Reason</th>
                            <th style="padding: 1rem;">Date</th>
                            <th style="padding: 1rem;">Status</th>
                            <th style="padding: 1rem;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in Model)
                        {
                            <tr style="@(report.IsResolved ? "opacity:0.7;" : "")">
                                <td class="align-middle">@report.Id</td>
                                <td class="align-middle">
                                    <div><strong>@report.ReporterName</strong></div>
                                    <small class="text-muted">@report.ReporterEmail</small>
                                </td>
                                <td class="align-middle">
                                    @if (report.Type == "Listing")
                                    {
                                        <span class="badge bg-info">Listing</span>
                                        <div class="mt-1">
                                            <a href="/Listings/Details/@report.ReportedListingId" target="_blank">
                                                @report.ReportedListingTitle
                                            </a>
                                        </div>
                                    }
                                    else if (report.Type == "User")
                                    {
                                        <span class="badge bg-warning">User</span>
                                        <div class="mt-1">@report.ReportedUserEmail</div>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">General</span>
                                    }
                                </td>
                                <td class="align-middle" style="max-width: 300px; white-space: normal;">
                                    @report.Reason
                                </td>
                                <td class="align-middle">@report.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="align-middle">
                                    @if (report.IsResolved)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle"></i> Resolved
                                        </span>
                                        <br />
                                        <small class="text-muted">@(report.ResolvedAt?.ToString("yyyy-MM-dd"))</small>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-clock"></i> Pending
                                        </span>
                                    }
                                </td>
                                <td class="align-middle">
                                    @if (!report.IsResolved)
                                    {
                                        <form method="post" asp-action="Resolve" asp-route-id="@report.Id" style="display: inline-block;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-success"
                                                    onclick="return confirm('Are you sure you want to resolve this report?')">
                                                <i class="bi bi-check-lg"></i> Resolve
                                            </button>
                                        </form>
                                    }
                                    
                                    <form method="post" asp-action="Delete" asp-route-id="@report.Id" style="display: inline-block;">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                                onclick="return confirm('Are you sure you want to delete this report?')">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox" style="font-size: 4rem; color: #94A3B8;"></i>
                <h3 class="mt-3 text-muted">No Reports</h3>
                <p class="text-muted">When users report violations, they will appear here</p>
            </div>
        }
    </div>
</section>