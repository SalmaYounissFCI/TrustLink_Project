@using SW_Project.ViewModels.Report
@model CreateReportVM
@{
    ViewData["Title"] = "Report a Violation";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-hero" style="padding: 6rem 0 3rem;">
    <div class="container">
        <span class="page-hero-eyebrow">Report</span>
        <h1 class="page-hero-title">Report @ViewBag.ReportType</h1>
        <p class="page-hero-desc">Please explain the issue in detail. Our admin team will review it.</p>
    </div>
</section>

<section class="profile-section" style="padding: 2rem 0 5rem;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="profile-card" style="padding: 2rem;">
                    <form method="post" asp-action="Create">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="ListingId" />
                        <input type="hidden" asp-for="ReportedUserId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display: none;"></div>

                        <div class="form-group-tl mb-4">
                            <label asp-for="Reason" class="form-label-tl">Reason for Report *</label>
                            <textarea asp-for="Reason" rows="6" class="form-input-tl"
                                      placeholder="Describe the issue in detail... (e.g., This listing violates our terms, this user is fraudulent, inappropriate content, etc.)"></textarea>
                            <span asp-validation-for="Reason" class="text-danger"></span>
                            <div class="form-text text-muted mt-2">
                                <i class="bi bi-info-circle"></i> This report will be sent securely to our admin team. The reported party will not be notified.
                            </div>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn-primary-tl">
                                <i class="bi bi-send"></i> Submit Report
                            </button>
                            <a href="javascript:history.back()" class="btn-outline-tl">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}