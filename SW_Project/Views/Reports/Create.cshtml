@using SW_Project.ViewModels.Report
@model CreateReportVM
@{
    ViewData["Title"] = "إبلاغ عن مخالفة";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="page-hero" style="padding: 6rem 0 3rem;">
    <div class="container">
        <span class="page-hero-eyebrow">Report</span>
        <h1 class="page-hero-title">إبلاغ عن @ViewBag.ReportType</h1>
        <p class="page-hero-desc">الرجاء توضيح سبب البلاغ بدقة، وسيتم مراجعته من قبل فريق الإدارة</p>
    </div>
</section>

<section class="profile-section" style="padding: 2rem 0 5rem;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="profile-card" style="padding: 2rem;">
                    <form method="post" asp-action="Create">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="ListingId" />
                        <input type="hidden" asp-for="ReportedUserId" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display: none;"></div>

                        <div class="form-group-tl mb-4">
                            <label asp-for="Reason" class="form-label-tl">سبب البلاغ *</label>
                            <textarea asp-for="Reason" rows="6" class="form-input-tl"
                                      placeholder="اكتب سبب البلاغ بالتفصيل... (مثال: إعلان مخالف للشروط، مستخدم قام بالاحتيال، محتوى غير لائق، إلخ)"></textarea>
                            <span asp-validation-for="Reason" class="text-danger"></span>
                            <div class="form-text text-muted mt-2">
                                <i class="bi bi-info-circle"></i> سيتم إرسال هذا البلاغ بشكل سري إلى فريق الإدارة، ولن يتم إبلاغ الطرف الآخر به.
                            </div>
                        </div>

                        <div class="d-flex gap-3">
                            <button type="submit" class="btn-primary-tl">
                                <i class="bi bi-send"></i> إرسال البلاغ
                            </button>
                            <a href="javascript:history.back()" class="btn-outline-tl">
                                <i class="bi bi-arrow-left"></i> إلغاء
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}